# ── Backend: Vertex AI (recommended — uses gcloud ADC, no quota issues) ──────
# Requires: gcloud auth application-default login
# Enable API: gcloud services enable aiplatform.googleapis.com --project=YOUR_PROJECT
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Backend: Gemini API (free tier — rate limits apply) ───────────────────────
# Uncomment and comment out the Vertex AI block above to switch back.
# GOOGLE_API_KEY=your_gemini_api_key_here
